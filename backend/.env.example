# PostgreSQL connection string — provided by Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# First admin account (created on first run)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me

# Path to the Railway persistent volume mount point
# In Railway: set this to /data/uploads (then mount your volume at /data)
UPLOAD_DIR=/data/uploads

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app
